  .cb-icon{ display:flex; align-items:center; gap:8px; font-size:12.5px; font-weight:600; color:var(--green); margin-bottom:14px; }

  .modal-submit{ width:100%; justify-content:center; padding:13px; font-size:14.5px; margin-top:6px; }

  .modal-success{ display:none; text-align:center; padding:20px 0 6px; }
  .modal-success.show{ display:block; }
  .modal-success .tick{
    width:52px; height:52px; border-radius:50%; background:var(--green-soft);

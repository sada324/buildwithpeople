  .modal-success p{ font-size:13.5px; color:var(--ink-soft); max-width:340px; margin:0 auto; }

  /* reveal on scroll */
  .reveal{ opacity:0; transform:translateY(16px); transition: opacity .6s ease, transform .6s ease; }

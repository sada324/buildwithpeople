<script>
  // contribution grid — signature element, GitHub-style history
  const grid = document.getElementById('contribGrid');
  const levels = ['','l1','l1','l2','l2','l2','l3','l3','l4'];
  let cells = '';
  for(let i=0;i<168;i++){
    const r = Math.random();
    let cls = '';
    if(r > 0.55) cls = levels[Math.floor(Math.random()*levels.length)];
    cells += `<i class="${cls}"></i>`;
  }
  grid.innerHTML = cells;

  // reveal on scroll
  const io = new IntersectionObserver((entries)=>{
    entries.forEach(e=>{ if(e.isIntersecting){ e.target.classList.add('in'); io.unobserve(e.target); } });
  }, { threshold: 0.12 });
  document.querySelectorAll('.reveal').forEach(el=>io.observe(el));

  // filter tabs (visual only)
  document.querySelectorAll('.filter').forEach(f=>{
    f.addEventListener('click', ()=>{
      document.querySelectorAll('.filter').forEach(x=>x.classList.remove('active'));
      f.classList.add('active');
    });
  });

  // list-your-company modal
  const overlay = document.getElementById('modalOverlay');
  const modalForm = document.getElementById('modalForm');
  const modalSuccess = document.getElementById('modalSuccess');
  const commissionBlock = document.getElementById('commissionBlock');

  function resetModal(){
    modalForm.style.display = 'block';
    modalSuccess.classList.remove('show');
    document.querySelectorAll('.chip-select').forEach(c=>c.classList.remove('selected'));
    commissionBlock.classList.remove('show');
    document.getElementById('companyName').value = '';
    document.getElementById('companyDesc').value = '';
    document.getElementById('dealPrice').value = '';
    document.getElementById('commRange').value = '';
  }

  function openModal(){
    overlay.classList.add('open');
    document.body.style.overflow = 'hidden';
  }
  function closeModal(){
    overlay.classList.remove('open');
    document.body.style.overflow = '';
    setTimeout(resetModal, 200);
  }

  document.querySelectorAll('.js-open-modal').forEach(btn=>{
    btn.addEventListener('click', openModal);
  });
  document.getElementById('modalClose').addEventListener('click', closeModal);
  overlay.addEventListener('click', (e)=>{ if(e.target === overlay) closeModal(); });
  document.addEventListener('keydown', (e)=>{ if(e.key === 'Escape' && overlay.classList.contains('open')) closeModal(); });

  // chip toggling
  document.querySelectorAll('#rolesGroup .chip-select').forEach(chip=>{
    chip.addEventListener('click', ()=> chip.classList.toggle('selected'));
  });
  document.querySelectorAll('#compGroup .chip-select').forEach(chip=>{
    chip.addEventListener('click', ()=>{
      chip.classList.toggle('selected');
      if(chip.dataset.commission){
        const anyCommission = document.querySelector('#compGroup .chip-select[data-commission="true"].selected');
        commissionBlock.classList.toggle('show', !!anyCommission);
      }
    });
  });

  document.getElementById('modalSubmit').addEventListener('click', ()=>{
    modalForm.style.display = 'none';
    modalSuccess.classList.add('show');
  });
</script>

</body>
</html>

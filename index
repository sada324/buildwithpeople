<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sales.io — Build companies with people who want to contribute</title>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700;800&family=Inter:wght@400;500;600&family=IBM+Plex+Mono:wght@400;500&display=swap');

  :root{
    --white:#ffffff;
    --off-white:#FAFAF8;
    --paper:#F6F6F4;
    --ink:#14171A;
    --ink-soft:#4B5157;
    --grey:#8A8F98;
    --border:#E7E7E3;
    --border-strong:#DADAD5;
    --green:#1E8E4F;
    --green-soft:#E9F5EE;
    --green-dot:#22B462;
    --shadow-sm: 0 1px 2px rgba(20,23,26,0.04), 0 1px 1px rgba(20,23,26,0.03);
    --shadow-md: 0 4px 16px rgba(20,23,26,0.06), 0 1px 3px rgba(20,23,26,0.04);
    --shadow-lg: 0 12px 40px rgba(20,23,26,0.08), 0 2px 8px rgba(20,23,26,0.04);
    --radius: 14px;
    --radius-sm: 8px;
    --font-display: 'Sora', 'Inter', sans-serif;
    --font-body: 'Inter', sans-serif;
    --font-mono: 'IBM Plex Mono', monospace;
  }

  *{ margin:0; padding:0; box-sizing:border-box; }
  html{ scroll-behavior:smooth; }
  body{
    font-family: var(--font-body);
    background: var(--white);
    color: var(--ink);
    -webkit-font-smoothing: antialiased;
    line-height:1.5;
  }
  ::selection{ background: var(--green-soft); color: var(--green); }
  a{ color:inherit; text-decoration:none; }
  button{ font-family:inherit; cursor:pointer; border:none; background:none; }
  img{ display:block; max-width:100%; }
  .wrap{ max-width:1180px; margin:0 auto; padding:0 32px; }

  :focus-visible{ outline: 2px solid var(--green); outline-offset: 2px; }

  @media (prefers-reduced-motion: reduce){
    *{ animation-duration:0.001ms !important; animation-iteration-count:1 !important; transition-duration:0.001ms !important; scroll-behavior:auto !important; }
  }

  /* ---------- dot ---------- */
  .dot{
    width:6px; height:6px; border-radius:50%;
    background: var(--green-dot);
    display:inline-block;
    position:relative;
    flex-shrink:0;
  }
  .dot::after{
    content:'';
    position:absolute; inset:-4px;
    border-radius:50%;
    background: var(--green-dot);
    opacity:0.28;
    animation: pulse 2.4s ease-in-out infinite;
  }
  @keyframes pulse{
    0%{ transform:scale(0.9); opacity:0.35; }
    70%{ transform:scale(1.9); opacity:0; }
    100%{ opacity:0; }
  }

  /* ---------- nav ---------- */
  header{
    position:sticky; top:0; z-index:100;
    background: rgba(255,255,255,0.86);
    backdrop-filter: blur(10px);
    border-bottom:1px solid var(--border);
  }
  nav{
    display:flex; align-items:center; justify-content:space-between;
    height:68px;
  }
  .logo{
    font-family:var(--font-display); font-weight:700; font-size:19px;
    letter-spacing:-0.02em; display:flex; align-items:center; gap:8px;
  }
  .logo .mark{
    width:9px; height:9px; border-radius:3px; background:var(--ink);
    display:inline-block; transform:rotate(45deg);
  }
  .nav-links{ display:flex; gap:34px; align-items:center; }
  .nav-links a{
    font-size:14px; color:var(--ink-soft); font-weight:500;
    transition: color .15s ease;
  }
  .nav-links a:hover{ color:var(--ink); }
  .nav-right{ display:flex; align-items:center; gap:18px; }
  .nav-right a{ font-size:14px; font-weight:500; color:var(--ink-soft); }
  .btn{
    font-size:14px; font-weight:600; padding:10px 18px; border-radius:9px;
    display:inline-flex; align-items:center; gap:8px;
    transition: transform .15s ease, box-shadow .15s ease, background .15s ease;
  }
  .btn-dark{ background:var(--ink); color:var(--white); }
  .btn-dark:hover{ transform:translateY(-1px); box-shadow:var(--shadow-md); }
  .btn-ghost{ border:1px solid var(--border-strong); color:var(--ink); background:var(--white); }
  .btn-ghost:hover{ border-color:var(--ink); }
  .btn-sm{ padding:8px 14px; font-size:13px; }
  @media (max-width:900px){ .nav-links{ display:none; } }

  /* ---------- hero ---------- */
  .hero{
    padding:88px 0 64px;
    background:
      radial-gradient(600px 300px at 85% -10%, rgba(30,142,79,0.05), transparent 70%),
      var(--white);
  }
  .hero-grid{
    display:grid; grid-template-columns: 1.05fr 0.95fr; gap:64px; align-items:center;
  }
  @media (max-width:960px){ .hero-grid{ grid-template-columns:1fr; } }

  .eyebrow{
    display:inline-flex; align-items:center; gap:8px;
    font-family:var(--font-mono); font-size:12px; letter-spacing:0.02em;
    color:var(--green); background:var(--green-soft);
    border:1px solid #D7ECDF; padding:6px 12px; border-radius:20px;
    margin-bottom:22px;
  }
  h1{
    font-family:var(--font-display); font-weight:700;
    font-size:clamp(34px,4.6vw,54px);
    letter-spacing:-0.03em; line-height:1.05; color:var(--ink);
    margin-bottom:22px;
  }
  .hero p.lead{
    font-size:17px; color:var(--ink-soft); max-width:520px; margin-bottom:32px;
  }
  .hero-ctas{ display:flex; gap:14px; margin-bottom:36px; flex-wrap:wrap; }
  .hero-ctas .btn{ padding:13px 22px; font-size:15px; }

  .avatar-row{ display:flex; align-items:center; gap:14px; }
  .avatars{ display:flex; }
  .avatars span{
    width:34px; height:34px; border-radius:50%;
    border:2.5px solid var(--white);
    margin-left:-10px;
    background: linear-gradient(135deg,#D8D8D2,#EFEFEB);
    display:flex; align-items:center; justify-content:center;
    font-family:var(--font-mono); font-size:11px; color:var(--ink-soft);
    position:relative;
  }
  .avatars span:first-child{ margin-left:0; }
  .avatars span::after{
    content:''; position:absolute; right:-1px; bottom:-1px;
    width:9px; height:9px; border-radius:50%; background:var(--green-dot);
    border:2px solid var(--white);
  }
  .avatar-row .label{ font-size:13.5px; color:var(--ink-soft); }
  .avatar-row .label b{ color:var(--ink); font-weight:600; }

  /* ---------- hero interface preview ---------- */
  .preview{
    background: var(--paper);
    border:1px solid var(--border);
    border-radius:20px;
    padding:18px;
    box-shadow: var(--shadow-lg);
  }
  .preview-top{
    display:flex; align-items:center; justify-content:space-between;
    padding:4px 8px 14px; border-bottom:1px solid var(--border); margin-bottom:14px;
  }
  .preview-top .live{
    display:flex; align-items:center; gap:7px; font-family:var(--font-mono);
    font-size:11.5px; color:var(--green);
  }
  .preview-top .title{ font-size:13px; color:var(--ink-soft); font-weight:500; }

  .company-card{
    background:var(--white); border:1px solid var(--border); border-radius:13px;
    padding:16px; margin-bottom:12px;
    transition: box-shadow .18s ease, transform .18s ease, border-color .18s ease;
  }
  .company-card:hover{ box-shadow:var(--shadow-md); transform:translateY(-2px); border-color:var(--border-strong); }
  .company-card:last-child{ margin-bottom:0; }
  .cc-head{ display:flex; align-items:center; justify-content:space-between; margin-bottom:8px; }
  .cc-name{ display:flex; align-items:center; gap:8px; font-weight:600; font-size:14.5px; }
  .cc-sub{ font-size:12.5px; color:var(--grey); margin-bottom:12px; }
  .cc-tags{ display:flex; gap:6px; flex-wrap:wrap; margin-bottom:12px; }
  .tag{
    font-size:11px; font-family:var(--font-mono); color:var(--ink-soft);
    background:var(--off-white); border:1px solid var(--border); padding:3px 8px; border-radius:6px;
  }
  .cc-foot{ display:flex; align-items:center; justify-content:space-between; }
  .cc-meta{ font-size:11.5px; color:var(--grey); display:flex; align-items:center; gap:6px; }
  .cc-btn{
    font-size:12px; font-weight:600; color:var(--ink); border:1px solid var(--border-strong);
    padding:6px 12px; border-radius:7px; background:var(--white);
    transition:border-color .15s ease, background .15s ease;
  }
  .cc-btn:hover{ border-color:var(--ink); background:var(--off-white); }
  .cc-progress{ height:4px; background:var(--border); border-radius:2px; overflow:hidden; margin-top:10px; }
  .cc-progress i{ display:block; height:100%; background:var(--green-dot); border-radius:2px; }

  /* ---------- section shell ---------- */
  section{ padding:96px 0; }
  .section-alt{ background:var(--off-white); }
  .section-head{ max-width:600px; margin-bottom:52px; }
  .kicker{
    font-family:var(--font-mono); font-size:12px; color:var(--green);
    text-transform:uppercase; letter-spacing:0.08em; margin-bottom:14px; display:block;
  }
  h2{
    font-family:var(--font-display); font-weight:700; font-size:clamp(26px,3vw,36px);
    letter-spacing:-0.02em; line-height:1.15; margin-bottom:14px;
  }
  .section-head p{ color:var(--ink-soft); font-size:15.5px; }

  /* ---------- browse companies + filters ---------- */
  .filters{ display:flex; flex-wrap:wrap; gap:10px; margin-bottom:44px; }
  .filter{
    font-size:13.5px; font-weight:500; padding:9px 16px; border-radius:8px;
    border:1px solid var(--border-strong); color:var(--ink-soft); background:var(--white);
    transition: all .15s ease;
  }
  .filter.active{ background:var(--ink); color:var(--white); border-color:var(--ink); }
  .filter:not(.active):hover{ border-color:var(--ink); color:var(--ink); }

  .company-grid{ display:grid; grid-template-columns:repeat(3,1fr); gap:20px; }
  @media (max-width:900px){ .company-grid{ grid-template-columns:1fr 1fr; } }
  @media (max-width:640px){ .company-grid{ grid-template-columns:1fr; } }

  .grid-card{
    background:var(--white); border:1px solid var(--border); border-radius:var(--radius);
    padding:22px; transition: box-shadow .18s ease, transform .18s ease, border-color .18s ease;
  }
  .grid-card:hover{ box-shadow:var(--shadow-md); transform:translateY(-3px); border-color:var(--border-strong); }
  .gc-top{ display:flex; align-items:center; justify-content:space-between; margin-bottom:6px; }
  .gc-name{ display:flex; align-items:center; gap:8px; font-family:var(--font-display); font-weight:600; font-size:16.5px; }
  .gc-desc{ font-size:13.5px; color:var(--ink-soft); margin-bottom:16px; min-height:38px; }
  .gc-label{ font-size:11px; color:var(--grey); font-family:var(--font-mono); margin-bottom:8px; text-transform:uppercase; letter-spacing:0.04em; }
  .gc-roles{ display:flex; flex-wrap:wrap; gap:6px; margin-bottom:14px; }
  .gc-comp{ display:flex; gap:6px; margin-bottom:18px; }
  .comp-pill{ font-size:11px; color:var(--green); background:var(--green-soft); padding:3px 9px; border-radius:6px; font-weight:600; }
  .gc-bottom{ display:flex; align-items:center; justify-content:space-between; padding-top:14px; border-top:1px solid var(--border); }
  .gc-active{ font-size:12px; color:var(--grey); display:flex; align-items:center; gap:6px; }

  /* ---------- pathways ---------- */
  .path-grid{ display:grid; grid-template-columns:repeat(3,1fr); gap:1px; background:var(--border); border:1px solid var(--border); border-radius:var(--radius); overflow:hidden; }
  @media (max-width:900px){ .path-grid{ grid-template-columns:1fr 1fr; } }
  @media (max-width:600px){ .path-grid{ grid-template-columns:1fr; } }
  .path{ background:var(--white); padding:30px 26px; transition: background .15s ease; }
  .path:hover{ background:var(--off-white); }
  .path .idx{ font-family:var(--font-mono); font-size:12px; color:var(--grey); margin-bottom:16px; display:block; }
  .path h3{ font-family:var(--font-display); font-size:17px; font-weight:600; margin-bottom:8px; letter-spacing:-0.01em; }
  .path p{ font-size:13.5px; color:var(--ink-soft); }

  /* ---------- certification / training ---------- */
  .cert-section{ display:grid; grid-template-columns:1fr 1fr; gap:64px; align-items:center; }
  @media (max-width:900px){ .cert-section{ grid-template-columns:1fr; gap:40px; } }
  .cert-list{ display:flex; flex-direction:column; gap:16px; margin-top:28px; }
  .cert-item{ display:flex; gap:14px; }
  .cert-icon{
    width:30px; height:30px; border-radius:8px; background:var(--off-white); border:1px solid var(--border);
    flex-shrink:0; display:flex; align-items:center; justify-content:center;
    font-family:var(--font-mono); font-size:12px; color:var(--ink-soft);
  }
  .cert-item h4{ font-size:14.5px; font-weight:600; margin-bottom:3px; }
  .cert-item p{ font-size:13px; color:var(--ink-soft); }

  .cert-card{
    background:var(--white); border:1px solid var(--border); border-radius:16px; padding:26px;
    box-shadow:var(--shadow-md);
  }
  .cert-card-head{ display:flex; align-items:center; justify-content:space-between; margin-bottom:20px; padding-bottom:18px; border-bottom:1px solid var(--border); }
  .cert-card-head .company{ display:flex; align-items:center; gap:10px; }
  .cert-badge{ width:36px; height:36px; border-radius:9px; background:var(--ink); color:var(--white); display:flex; align-items:center; justify-content:center; font-family:var(--font-display); font-weight:700; font-size:13px; }
  .cert-title{ font-weight:600; font-size:14.5px; }
  .cert-sub{ font-size:12px; color:var(--grey); }
  .status-chip{ font-size:11.5px; font-weight:600; color:var(--green); background:var(--green-soft); padding:5px 11px; border-radius:20px; display:flex; align-items:center; gap:6px; }
  .cert-metrics{ display:grid; grid-template-columns:repeat(3,1fr); gap:14px; }
  .metric{ text-align:left; }
  .metric .num{ font-family:var(--font-mono); font-size:clamp(16px,2.2vw,24px); font-weight:500; color:var(--ink); display:block; white-space:nowrap; }
  .metric .lbl{ font-size:11.5px; color:var(--grey); margin-top:2px; }

  /* ---------- contribution profile (signature) ---------- */
  .profile-wrap{ display:grid; grid-template-columns:0.85fr 1.15fr; gap:56px; align-items:center; }
  @media (max-width:900px){ .profile-wrap{ grid-template-columns:1fr; gap:40px; } }
  .profile-card{
    background:var(--white); border:1px solid var(--border); border-radius:16px; padding:28px;
    box-shadow:var(--shadow-md);
  }
  .profile-id{ display:flex; align-items:center; gap:12px; margin-bottom:22px; }
  .profile-avatar{
    width:46px; height:46px; border-radius:50%; background:linear-gradient(135deg,#D8D8D2,#EFEFEB);
    display:flex; align-items:center; justify-content:center; font-family:var(--font-mono); font-size:14px; color:var(--ink-soft);
    position:relative;
  }
  .profile-avatar::after{ content:''; position:absolute; right:0; bottom:0; width:11px; height:11px; border-radius:50%; background:var(--green-dot); border:2px solid var(--white); }
  .profile-name{ font-weight:600; font-size:15.5px; }
  .profile-role{ font-size:12.5px; color:var(--grey); }
  .profile-stats{ display:grid; grid-template-columns:repeat(3,1fr); gap:14px; margin-bottom:24px; padding-bottom:22px; border-bottom:1px solid var(--border); }

  .contrib-label{ font-size:12px; color:var(--grey); font-family:var(--font-mono); margin-bottom:10px; display:flex; justify-content:space-between; }
  .contrib-grid{
    display:grid; grid-template-columns:repeat(24,1fr); gap:3px;
  }
  .contrib-grid i{ display:block; padding-top:100%; border-radius:2px; background:var(--border); }
  .contrib-grid i.l1{ background:#D6EEDF; }
  .contrib-grid i.l2{ background:#A6DCBB; }
  .contrib-grid i.l3{ background:#5EC085; }
  .contrib-grid i.l4{ background:var(--green-dot); }

  .profile-copy .section-head{ margin-bottom:36px; }
  .profile-feats{ display:flex; flex-direction:column; gap:18px; }
  .profile-feat{ display:flex; gap:14px; align-items:flex-start; }
  .profile-feat .d{ margin-top:7px; }
  .profile-feat h4{ font-size:14.5px; font-weight:600; margin-bottom:3px; }
  .profile-feat p{ font-size:13px; color:var(--ink-soft); }

  /* ---------- for companies ---------- */
  .companies-panel{
    display:grid; grid-template-columns:1fr 1fr; gap:56px; align-items:center;
  }
  @media (max-width:900px){ .companies-panel{ grid-template-columns:1fr; gap:36px; } }
  .checklist{ display:flex; flex-direction:column; gap:14px; margin-top:26px; }
  .check-item{ display:flex; gap:12px; align-items:flex-start; font-size:14px; color:var(--ink-soft); }
  .check-item svg{ flex-shrink:0; margin-top:2px; }

  .mock-dashboard{
    background:var(--paper); border:1px solid var(--border); border-radius:16px; padding:20px;
    box-shadow:var(--shadow-md);
  }
  .mock-row{
    background:var(--white); border:1px solid var(--border); border-radius:10px; padding:14px 16px;
    display:flex; align-items:center; justify-content:space-between; margin-bottom:10px;
  }
  .mock-row:last-child{ margin-bottom:0; }
  .mock-left{ display:flex; align-items:center; gap:10px; font-size:13.5px; font-weight:500; }
  .mock-tag{ font-size:11px; color:var(--grey); font-family:var(--font-mono); }
  .mini-avatars{ display:flex; }
  .mini-avatars span{ width:22px; height:22px; border-radius:50%; background:linear-gradient(135deg,#D8D8D2,#EFEFEB); border:2px solid var(--white); margin-left:-7px; }
  .mini-avatars span:first-child{ margin-left:0; }

  /* ---------- activity feed ---------- */
  .feed{
    background:var(--white); border:1px solid var(--border); border-radius:16px; overflow:hidden;
    box-shadow:var(--shadow-sm);
  }
  .feed-item{
    display:flex; align-items:center; gap:14px; padding:16px 22px;
    border-bottom:1px solid var(--border);
    transition: background .15s ease;
  }
  .feed-item:hover{ background:var(--off-white); }
  .feed-item:last-child{ border-bottom:none; }
  .feed-text{ font-size:14px; color:var(--ink); flex:1; }
  .feed-text b{ font-weight:600; }
  .feed-time{ font-size:12px; color:var(--grey); font-family:var(--font-mono); white-space:nowrap; }

  /* ---------- final cta ---------- */
  .final-cta{
    background: var(--ink);
    color:var(--white);
    border-radius:24px;
    padding:72px 56px;
    text-align:center;
    position:relative;
    overflow:hidden;
  }
  .final-cta::before{
    content:'';
    position:absolute; inset:0;
    background: radial-gradient(500px 260px at 50% 0%, rgba(34,180,98,0.14), transparent 70%);
  }
  .final-cta > *{ position:relative; }
  .final-cta h2{ color:var(--white); max-width:640px; margin:0 auto 16px; }
  .final-cta p{ color:#B7BAC0; max-width:480px; margin:0 auto 34px; font-size:15.5px; }
  .final-ctas{ display:flex; justify-content:center; gap:14px; flex-wrap:wrap; }
  .final-cta .btn-dark{ background:var(--white); color:var(--ink); }
  .final-cta .btn-ghost{ background:transparent; color:var(--white); border-color:#3A3D42; }
  .final-cta .btn-ghost:hover{ border-color:#6a6d72; }

  footer{ border-top:1px solid var(--border); padding:44px 0 32px; }
  .foot-row{ display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:20px; }
  .foot-links{ display:flex; gap:26px; }
  .foot-links a{ font-size:13.5px; color:var(--ink-soft); }
  .foot-links a:hover{ color:var(--ink); }
  .foot-copy{ font-size:13px; color:var(--grey); }

  /* ---------- list-company modal ---------- */
  .modal-overlay{
    position:fixed; inset:0; z-index:1000;
    background:rgba(20,23,26,0.42);
    backdrop-filter: blur(3px);
    display:flex; align-items:center; justify-content:center;
    padding:24px;
    opacity:0; pointer-events:none;
    transition: opacity .2s ease;
  }
  .modal-overlay.open{ opacity:1; pointer-events:auto; }
  .modal{
    background:var(--white);
    border:1px solid var(--border);
    border-radius:18px;
    width:100%; max-width:540px;
    max-height:88vh; overflow-y:auto;
    box-shadow:var(--shadow-lg);
    padding:32px;
    transform:translateY(10px) scale(0.98);
    transition: transform .22s ease;
  }
  .modal-overlay.open .modal{ transform:translateY(0) scale(1); }
  .modal-head{ display:flex; align-items:flex-start; justify-content:space-between; margin-bottom:6px; }
  .modal-head h3{ font-family:var(--font-display); font-size:21px; font-weight:700; letter-spacing:-0.02em; }
  .modal-close{
    width:30px; height:30px; border-radius:8px; display:flex; align-items:center; justify-content:center;
    color:var(--grey); border:1px solid var(--border); flex-shrink:0;
    transition: all .15s ease;
  }
  .modal-close:hover{ color:var(--ink); border-color:var(--ink); }
  .modal-sub{ font-size:13.5px; color:var(--ink-soft); margin-bottom:26px; }

  .field-group{ margin-bottom:22px; }
  .field-label{ font-size:13px; font-weight:600; color:var(--ink); margin-bottom:9px; display:block; }
  .field-hint{ font-size:12px; color:var(--grey); margin-top:6px; }
  .field-input, .field-textarea{
    width:100%; border:1px solid var(--border-strong); border-radius:9px;
    padding:11px 13px; font-size:14px; font-family:var(--font-body); color:var(--ink);
    background:var(--off-white);
    transition: border-color .15s ease, background .15s ease;
  }
  .field-input:focus, .field-textarea:focus{ border-color:var(--green); background:var(--white); }
  .field-textarea{ resize:vertical; min-height:64px; }
  .field-row{ display:grid; grid-template-columns:1fr 1fr; gap:12px; }

  .chip-group{ display:flex; flex-wrap:wrap; gap:8px; }
  .chip-select{
    font-size:13px; font-weight:500; padding:8px 14px; border-radius:8px;
    border:1px solid var(--border-strong); color:var(--ink-soft); background:var(--white);
    transition: all .15s ease;
